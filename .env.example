# Database
DATABASE_URL=postgres://crm_user:crm_password@localhost:5432/taxpod_crm

# LLM Provider (google | anthropic)
LLM_PROVIDER=google

# Google Gemini (default — free tier at https://aistudio.google.com/)
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server
PORT=3000
NODE_ENV=development
